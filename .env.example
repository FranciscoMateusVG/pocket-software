# Google Analytics 4 Measurement ID
# Get yours at: https://analytics.google.com → Admin → Data Streams → Measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Cal.com self-hosted instance (optional — Cal.com section hidden if not set)
NEXT_PUBLIC_CALCOM_URL=https://cal.yourdomain.com
NEXT_PUBLIC_CALCOM_EVENT_SLUG=conversa-projeto

# GoDaddy Titan Email SMTP settings for contact form
# IMPORTANT: Server-side only — do NOT add NEXT_PUBLIC_ prefix
SMTP_HOST=smtp.titan.email
SMTP_PORT=465
SMTP_USER=your-email@yourdomain.com
SMTP_PASS=your-email-password
